  "decisions": [
    {
      "decision_id": "dec-001",
      "title": "Allow agents to auto-update production constraints from llm_derived sources",
      "status": "ratified",
      "risk_level": "high",
      "proposer_principal_id": "agent-claude",
      "proposal": {
        "assumptions": [
          "Agents have sufficient context to identify outdated constraints",
          "llm_derived sources are reliable when cross-referenced"
        ],
        "evidence_ids": ["mem-004", "load-test-report-001"],
        "risks": [
          "Governance bypass: agent could override human-set constraints",
          "Trust escalation: llm_derived → production without human gate"
        ],
        "trade_offs": [
          "Faster iteration vs governance safety",
          "Automation efficiency vs human oversight"
        ],
        "rollback_plan": "Revert to manual constraint review process; restore mem-003 original value",
        "implementation_steps": [
          "Add auto-update capability to architect role",
          "Set risk_threshold check before constraint modification",
          "Log all auto-updates to audit trail"
        ]
      },
      "reviews": [
        {
          "review_id": "review-001",
          "decision_id": "dec-001",
          "reviewer_principal_id": "agent-codex",
          "reviewer_role_id": "role-engineer",
          "position": "oppose",
          "reasoning": "Allowing agents to auto-modify production constraints from llm_derived sources bypasses the core governance principle: human confirmation is required for production-affecting changes. The risk_threshold mechanism is insufficient — it measures confidence, not correctness. A highly confident but wrong LLM output would pass the gate. This should require human_confirmed tier at minimum.",
          "risk_categories_addressed": ["governance_bypass", "trust_escalation"],
          "evidence_ids": ["mem-002", "mem-007"]
        },
        {
          "review_id": "review-002",
          "decision_id": "dec-001",
          "reviewer_principal_id": "agent-gemini",
          "reviewer_role_id": "role-engineer",
          "position": "conditional_approve",
          "reasoning": "The proposal has merit for non-critical constraints, but production-affecting constraints must retain human gate. Suggest: allow auto-update only for constraints tagged as 'operational' (e.g., rate limits), require human_confirmed for 'governance' constraints (e.g., deployment rules). Add a 24h cooling period before auto-updates take effect.",
          "risk_categories_addressed": ["governance_bypass"],
          "evidence_ids": ["mem-004"]
        }
      ],
      "ratification": {
        "ratified_by": "maki",
        "rationale": "Accepting Gemini's conditional approach: auto-update allowed for operational constraints only, with 24h cooling period. Governance constraints require human_confirmed. Codex's concern about confidence ≠ correctness is valid — adding cross-reference requirement.",
        "review_addressal": "Codex dissent incorporated: governance constraints excluded from auto-update. Gemini condition adopted: 24h cooling + operational-only scope."
      },
      "created_at": "2026-06-14T09:00:00Z",
      "effective_at": "2026-06-14T17:00:00Z",
      "review_deadline": "2026-06-14T15:00:00Z"
    }
  ],
