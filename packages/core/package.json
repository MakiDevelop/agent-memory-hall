{
  "name": "@chibakuma/agent-memory-hall",
  "version": "0.6.0",
  "description": "MCP-native memory server with built-in governance for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-memory-hall": "dist/cli.js",
    "amh": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "start": "node dist/mcp/server.js",
    "check": "tsc --noEmit",
    "test": "tsc && node --test $(find dist -name '*.test.js')",
    "verify-pack": "npm run build && npm pack --dry-run 2>&1 | tee /tmp/amh-pack.log && ! grep -E 'dist/.*\\.test\\.' /tmp/amh-pack.log",
    "prepublishOnly": "npm run check && npm run build && npm run verify-pack"
  },
  "keywords": [
    "agent",
    "memory",
    "mcp",
    "governance",
    "ai"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakiDevelop/agent-memory-hall.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/hashes": "^1.8.0",
    "better-sqlite3": "^12.10.1",
    "pg": "^8.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.0"
  }
}
